generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model BwaEntry {
  id             String   @id @default(cuid())
  month          Int
  year           Int
  filename       String
  filePath       String
  uploadedAt     DateTime @default(now())
  revenue        Float?
  personnelCosts Float?
  operatingCosts Float?
  profit         Float?
  cashPosition   Float?
  notes          String?

  @@unique([year, month], name: "bwa_year_month")
  @@index([uploadedAt])
}

model TaxPayment {
  id        String   @id @default(cuid())
  date      DateTime
  type      String
  amount    Float
  quarter   Int?
  year      Int
  notes     String?
  status    String   @default("active")
  createdAt DateTime @default(now())

  @@index([year, status])
}

model TaxConfig {
  id              String   @id @default(cuid())
  year            Int      @unique
  hebesatz        Float    @default(400)
  estRatePartner1 Float    @default(35)
  estRatePartner2 Float    @default(35)
  profitSplitP1   Float    @default(50)
  updatedAt       DateTime @updatedAt
}

model Customer {
  id            String   @id @default(cuid())
  name          String
  contactPerson String?
  email         String?
  phone         String?
  status        String   @default("active")

  contractStart DateTime
  contractEnd   DateTime
  paymentModel  String
  paymentDay    Int
  paymentMethod String
  paymentConfig String
  closingDate   DateTime?

  contractSigned Boolean @default(false)
  contractFile   String?

  notes      String?
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt
  paymentEntries PaymentScheduleEntry[]
  otherPayments  OtherPayment[]

  @@index([status])
  @@index([contractStart])
}

model PaymentScheduleEntry {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  dueMonth Int
  dueYear  Int
  dueDay   Int

  amount    Float
  entryType String

  invoiceSent   Boolean   @default(false)
  invoiceSentAt DateTime?
  sepaConfirmed Boolean   @default(false)
  paid          Boolean   @default(false)
  paidAt        DateTime?

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dueYear, dueMonth])
  @@index([customerId])
}

model OtherPayment {
  id          String   @id @default(cuid())
  customerId  String?
  customer    Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  title       String
  kind        String   @default("other_payment")
  category    String
  salesType   String   @default("other")
  includeInAv Boolean  @default(false)
  planGroupId String?
  planType    String?
  planConfig  String?
  amount      Float
  paymentDate DateTime
  month       Int
  year        Int
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([year, month])
  @@index([customerId])
  @@index([kind])
  @@index([planGroupId])
}
